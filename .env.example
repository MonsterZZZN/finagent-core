# ============================================================
# finagent-core 环境变量模板
# 用法：复制本文件为 .env，填入真实值（.env 不会提交到 git）
#   cp .env.example .env
# ============================================================

# ===== 大模型 API（必填）=====
DEEPSEEK_API_KEY=sk-在这里填你的DeepSeek密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 备用模型（可选，留空则不启用）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== 数据库（与 docker-compose 对应）=====
MONGODB_URI=mongodb://root:finagent2026@127.0.0.1:27017/?authSource=admin
MONGODB_DB_NAME=finagent
REDIS_URL=redis://127.0.0.1:6379/0

# ===== 跨项目服务地址（做到集成时再填）=====
RESEARCH_SERVICE_URL=
KB_SERVICE_URL=

# ===== 飞书渠道（接飞书时填）=====
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ===== MCP Server =====
MCP_HOST=127.0.0.1
MCP_PORT=8003
MCP_PATH=/mcp

# ===== 运行环境 =====
APP_ENV=development
